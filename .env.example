# Production public URL (required on Railway for OAuth redirects)
BASE_URL=https://your-app.up.railway.app

# Create a free cluster on MongoDB Atlas and paste the connection string here
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/project_matchmaker?retryWrites=true&w=majority

# GitHub OAuth Credentials (Optional - Mock Login works out of the box without these!)
# Create a developer application on GitHub with callback: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cloudinary Credentials (Optional - Local disk storage fallback is used if these are blank!)
# Register a free account on Cloudinary to get these credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Socket Server Port (Default is 3001)
PORT=3001
